{
  "permissions": {
    "allow": [
      "Bash(aigon:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo:*)",
      "Bash(su:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jviner/.local/state/fnm_multishells/47908_1776068105296/bin/aigon check-version",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "/Users/jviner/.local/state/fnm_multishells/47908_1776068105296/bin/aigon project-context",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jviner/.local/state/fnm_multishells/47908_1776068105296/bin/aigon capture-session-telemetry",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jviner/.local/state/fnm_multishells/47908_1776068105296/bin/aigon check-agent-submitted",
            "timeout": 5
          }
        ]
      }
    ]
  }
}