{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jviner/.local/state/fnm_multishells/47908_1776068105296/bin/aigon check-version",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "/Users/jviner/.local/state/fnm_multishells/47908_1776068105296/bin/aigon project-context",
            "timeout": 10
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jviner/.local/state/fnm_multishells/47908_1776068105296/bin/aigon check-agent-signal",
            "timeout": 5
          }
        ]
      }
    ]
  }
}